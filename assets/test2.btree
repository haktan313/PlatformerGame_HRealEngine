      AttackPower: 10
      AmmoCount: 30
    Bools:
      IsPlayerInRange: false
      IsAttacking: false
      CanAttack: true
    Strings:
      CurrentState: Idle
  EditorData:
    Nodes:
      - ID: 1
        Name: Root
        Type: 1
        RuntimeUID: 1
        Class: class HRootNode
        PosX: 0
        PosY: 0
        Decorators:
          []
        Conditions:
          []
        Params:
          {}
      - ID: 3
        Name: Selector
        Type: 3
        RuntimeUID: 2
        Class: class SelectorNode
        PosX: -12
        PosY: 110
        Decorators:
          []
        Conditions:
          []
        Params:
          {}
      - ID: 9
        Name: AttackAction
        Type: 4
        RuntimeUID: 6
        Class: class HRealEngine::ManagedBTAction
        PosX: 132
        PosY: 218
        Decorators:
          - Name: CooldownDecorator
            ClassName: CooldownDecorator
            Params:
              CooldownTime: 5
              ResetOnFail: false
        Conditions:
          - Name: CanAttack
            ClassName: CanAttack
            Params:
              Priority: Both
              CanAttackKey: CanAttack
        Params:
          Damage: 10
          StaminaKey: Stamina
      - ID: 11
        Name: MoveToPlayerAction
        Type: 4
        RuntimeUID: 3
        Class: class HRealEngine::ManagedBTAction
        PosX: -156
        PosY: 250
        Decorators:
          []
        Conditions:
          - Name: IsInTheRange
            ClassName: IsInTheRange
            Params:
              Priority: Both
              DistanceKey: DistanceToPlayer
              MinRange: 250
        Params:
          StopDistance: 31
          MoveSpeed: 5
          DistanceKey: DistanceToPlayer
    Links:
      - ID: 16
        StartNodeID: 1
        EndNodeID: 3
      - ID: 21
        StartNodeID: 3
        EndNodeID: 11
      - ID: 22
        StartNodeID: 3
        EndNodeID: 9
  RuntimeData:
    Name: Root
    Type: Root
    Class: class HRootNode
    Children:
      - Name: Selector
        Type: Composite
        Class: class SelectorNode
        Children:
          - Name: MoveToPlayerAction
            Type: Action
            Class: class HRealEngine::ManagedBTAction
            Conditions:
              - Name: IsInTheRange
